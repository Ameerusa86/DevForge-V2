AUTH_GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx"
AUTH_GOOGLE_CLIENT_ID="123456789012-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com"

AUTH_GITHUB_CLIENT_SECRET="0123456789abcdef0123456789abcdef01234567"
AUTH_GITHUB_CLIENT_ID="Ov23lijxxxxxxxxxxxxxxxxxx"

BETTER_AUTH_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
BETTER_AUTH_URL="http://localhost:3000"

DATABASE_URL="postgresql://username:password@localhost:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://username:password@localhost:5432/postgres"

# Supabase project
SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase S3-compatible storage
SUPABASE_S3_ENDPOINT=https://your-project-id.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-west-2
# Get these from Supabase: Storage -> S3 credentials
SUPABASE_S3_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Create a public bucket in Supabase Storage and put its name here
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=your-storage-bucket
